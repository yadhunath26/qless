<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F7F8FA">

    <!-- Top blue accent blob -->
    <View
        android:id="@+id/blobTop"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:background="@drawable/blob_blue"
        android:alpha="0.08"
        android:translationX="80dp"
        android:translationY="-100dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Logo / Icon area -->
    <FrameLayout
        android:id="@+id/logoContainer"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginTop="48dp"
        android:background="@drawable/circle_blue_solid"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_shopping_cart"
            android:tint="#FFFFFF" />
    </FrameLayout>

    <!-- Welcome text block -->
    <LinearLayout
        android:id="@+id/textBlock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="28dp"
        android:paddingHorizontal="32dp"
        app:layout_constraintTop_toBottomOf="@id/logoContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to"
            android:textSize="16sp"
            android:textColor="#94A3B8"
            android:letterSpacing="0.04" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="QLess"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:letterSpacing="-0.02" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Your intelligent shopping companion.\nScan, track and checkout in seconds."
            android:textSize="14sp"
            android:textColor="#64748B"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5" />
    </LinearLayout>

    <!-- Feature pills row -->
    <LinearLayout
        android:id="@+id/pillsRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/textBlock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📷  Scan"
            android:textSize="12sp"
            android:textColor="#2563EB"
            android:background="@drawable/chip_blue_bg"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛒  Track"
            android:textSize="12sp"
            android:textColor="#0F172A"
            android:background="@drawable/chip_neutral_bg"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧾  Bill"
            android:textSize="12sp"
            android:textColor="#0F172A"
            android:background="@drawable/chip_neutral_bg"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />
    </LinearLayout>

    <!-- Divider line -->
    <View
        android:id="@+id/dividerLine"
        android:layout_width="48dp"
        android:layout_height="3dp"
        android:layout_marginTop="28dp"
        android:background="#E2E8F0"
        app:layout_constraintTop_toBottomOf="@id/pillsRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Camera preview (hidden until scan starts) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:layout_marginTop="28dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:visibility="gone"
        android:background="#0F172A"
        app:layout_constraintTop_toBottomOf="@id/dividerLine"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scanning hint (hidden until scan starts) -->
    <TextView
        android:id="@+id/txtScanHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Point camera at the QR code on your cart"
        android:textSize="12sp"
        android:textColor="#64748B"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/previewView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom action area -->
        <LinearLayout
            android:id="@+id/bottomActions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="32dp"
            app:layout_constraintTop_toBottomOf="@id/txtScanHint"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <!-- Main scan button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScanQr"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Start Scanning"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:backgroundTint="#2563EB"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_qr_code_scanner"
            app:iconGravity="textStart"
            app:iconTint="#FFFFFF"
            app:iconPadding="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:text="QLess · Next-Gen Onboarding For Quick Shopping"
            android:textSize="11sp"
            android:textColor="#CBD5E1"
            android:letterSpacing="0.05" />

    </LinearLayout>

    <!-- Mode text (hidden, used by logic) -->
    <TextView
        android:id="@+id/txtMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mode: --"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>